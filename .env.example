# X / Supabase / auth — see existing deployment docs

# ScorePayout on BSC (testnet = 97, mainnet = 56)
PAYOUT_CONTRACT_ADDRESS=0xYourScorePayoutContract
PAYOUT_CHAIN_ID=97
NEXT_PUBLIC_PAYOUT_CONTRACT_ADDRESS=0xYourScorePayoutContract
NEXT_PUBLIC_PAYOUT_CHAIN_ID=97
# Must match ScorePayout constructor _signer (voucher signing only)
SIGNER_PRIVATE_KEY=0x64_hex_chars_server_only
# Must match ScorePayout constructor _operator (openEpoch only)
PAYOUT_OPERATOR_PRIVATE_KEY=0x64_hex_chars_server_only
PAYOUT_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Mundial Rewards — Solana USDC vault (devnet until audited)
# Use placeholder program id until deploy finishes, then replace.
MUNDIAL_REWARDS_PROGRAM_ID=11111111111111111111111111111111
NEXT_PUBLIC_MUNDIAL_REWARDS_PROGRAM_ID=11111111111111111111111111111111
USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
NEXT_PUBLIC_USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
# Server-only — Ed25519 signer (64-byte JSON array, base58, or hex secret key)
SOLANA_SIGNER_SECRET_KEY=
# Server-only — operator keypair for open_epoch
SOLANA_OPERATOR_SECRET_KEY=
# Optional default pot when running: npm run open:solana-epoch
SOLANA_OPEN_EPOCH_POT_USDC=1.00
