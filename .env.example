# Copy to .env.local — never commit secrets.

# --- NextAuth (X / Twitter sign-in) ---
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Supabase (Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL for migration scripts
# DATABASE_URL=postgresql://postgres:...@db....supabase.co:5432/postgres

# --- TxLINE (TxOdds World Cup) ---
# Activate via txodds/get-txodds-key.mjs → save token here
TXODDS_API_TOKEN=
# Default: https://txline-dev.txodds.com — use https://txline.txodds.com for mainnet tier
# TXODDS_API_ORIGIN=https://txline.txodds.com

# --- X API (prediction collection from match threads) ---
X_BEARER_TOKEN=
X_MATCH_ACCOUNT=copamundialapp

# X reply bot (growth) — posts a single reply to new predictors. Defaults OFF.
# Requires OAuth 1.0a *user* tokens for @copamundialapp (Bearer alone cannot post).
# X_REPLY_BOT_ENABLED=false
# X_REPLY_BOT_FIRST_TIME_ONLY=false
# X_REPLY_BOT_MAX_PER_HOUR=10
# X_REPLY_BOT_MAX_PER_RUN=5
# X_REPLY_BOT_MIN_GAP_MS=8000
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# --- Cron / admin (Vercel production) ---
CRON_SECRET=
COLLECT_SECRET=

# Discord webhook — daily leaderboard image posted after 10:00 UTC snapshot
# DISCORD_LEADERBOARD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Solana USDC payouts (devnet) ---
MUNDIAL_REWARDS_PROGRAM_ID=2GvW9gBcFmmUcoQDoBVQe9rpR1dGzD4uTdaLzzwRzRz9
USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
NEXT_PUBLIC_USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
# Server-only — Ed25519 voucher signer + epoch operator
SOLANA_SIGNER_SECRET_KEY=
SOLANA_OPERATOR_SECRET_KEY=
# Daily epoch pot (USDC) — snapshot cron and open:solana-epoch use this when set
SOLANA_DAILY_POT_USDC=2000
# Devnet: auto-mint shortfall into vault before snapshot/open (default on devnet RPC)
SOLANA_AUTO_MINT_VAULT=true
# Playground deploy wallet / on-chain admin — USDC mint authority on devnet
# SOLANA_USDC_MINT_AUTHORITY_SECRET_KEY=
# SOLANA_ADMIN_SECRET_KEY=
# Epoch ids: calendar YYYYMMDD when FIRST_SNAPSHOT_EPOCH_ID is set (default)
# SOLANA_EPOCH_ID_MODE=calendar
