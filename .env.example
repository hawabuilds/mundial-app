# Copy to .env.local — never commit secrets.

# --- NextAuth (X / Twitter sign-in) ---
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Supabase (Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URL for migration scripts
# DATABASE_URL=postgresql://postgres:...@db....supabase.co:5432/postgres

# --- TxLINE (TxOdds World Cup) ---
# Activate via txodds/get-txodds-key.mjs → save token here
TXODDS_API_TOKEN=
# Default: https://txline-dev.txodds.com — use https://txline.txodds.com for mainnet tier
# TXODDS_API_ORIGIN=https://txline.txodds.com

# --- X API (prediction collection from match threads) ---
X_BEARER_TOKEN=
X_MATCH_ACCOUNT=copamundialapp

# --- Cron / admin (Vercel production) ---
CRON_SECRET=
COLLECT_SECRET=

# --- Solana USDC payouts (devnet) ---
MUNDIAL_REWARDS_PROGRAM_ID=2GvW9gBcFmmUcoQDoBVQe9rpR1dGzD4uTdaLzzwRzRz9
USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
NEXT_PUBLIC_USDC_MINT=BjtWiAFKjrdvweA7Cer4MMWPRGNmpGGY9ixJwoZzfkFU
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
# Server-only — Ed25519 voucher signer + epoch operator
SOLANA_SIGNER_SECRET_KEY=
SOLANA_OPERATOR_SECRET_KEY=
# Optional default pot for npm run demo:epoch / open:solana-epoch
SOLANA_OPEN_EPOCH_POT_USDC=1.00
